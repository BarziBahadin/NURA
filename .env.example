# NURA Configuration
APP_ENV=development
COMPANY_NAME=Your Company
AGENT_NAME=NURA
AGENT_TONE=formal
PRIMARY_LANGUAGE=Arabic

API_HOST=0.0.0.0
API_PORT=8000
API_KEY=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nura_db
POSTGRES_USER=nura_user
POSTGRES_PASSWORD=

REDIS_HOST=redis
REDIS_PORT=6379

CHROMA_HOST=chromadb
CHROMA_PORT=8001

RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=3
