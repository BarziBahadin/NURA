# NURA Configuration
# Use development locally. Production enables stricter startup checks.
APP_ENV=development
COMPANY_NAME=Your Company
AGENT_NAME=NURA
AGENT_TONE=formal
PRIMARY_LANGUAGE=Arabic

API_HOST=0.0.0.0
API_PORT=8000
API_KEY=
ALLOW_ADMIN_API_KEY=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nura_db
POSTGRES_USER=nura_user
POSTGRES_PASSWORD=

REDIS_HOST=redis
REDIS_PORT=6379

CHROMA_HOST=chromadb
CHROMA_PORT=8000

RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=3
UNKNOWN_ANSWER_BEHAVIOR=handoff

ML_MODEL_PATH=/app/ml_models/local_model.pkl
ML_VECTORIZER_PATH=/app/ml_models/vectorizer.pkl
ML_CONFIDENCE_THRESHOLD=0.70
# Development can run without hashes while iterating. Production must set this to true.
ML_REQUIRE_ARTIFACT_HASHES=false
USE_SEMANTIC_EMBEDDINGS=false
SEMANTIC_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2

HANDOFF_ENABLED=true
HANDOFF_TRIGGERS=angry_sentiment,explicit_request,two_failures,keywords
ESCALATION_WEBHOOK_URL=

TELEGRAM_BOT_TOKEN=
TELEGRAM_POLLER_ENABLED=true

BACKGROUND_JOBS_ENABLED=true
JOB_WORKER_ENABLED=true
JOB_MAX_ATTEMPTS=3
JOB_RETRY_DELAY_SECONDS=5

# Production requires at least 32 characters.
ADMIN_SECRET_KEY=
ADMIN_USERNAME=admin
# Production requires a strong password of at least 12 characters.
ADMIN_PASSWORD=
ADMIN_TOKEN_TTL_SECONDS=28800

DB_AUTO_INIT=true

CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3004,http://localhost:5173,http://localhost:8080,http://localhost:9000
