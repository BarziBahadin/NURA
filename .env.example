BACKGROUND_JOBS_ENABLED=true
JOB_WORKER_ENABLED=true
JOB_MAX_ATTEMPTS=3
JOB_RETRY_DELAY_SECONDS=5

ADMIN_SECRET_KEY=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
