# NURA Configuration - Rcell Telecom
COMPANY_NAME=Rcell Telecom
AGENT_NAME=NURA
AGENT_TONE=formal
PRIMARY_LANGUAGE=Arabic

API_HOST=0.0.0.0
API_PORT=8000
API_KEY=

OLLAMA_HOST=http://host.docker.internal:11434
LLM_MODEL=llama3.1:8b
EMBEDDING_MODEL=nomic-embed-text

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nura_db
POSTGRES_USER=nura_user
POSTGRES_PASSWORD=

REDIS_HOST=redis
REDIS_PORT=6379

CHROMA_HOST=chromadb
CHROMA_PORT=8001

RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=3
UNKNOWN_ANSWER_BEHAVIOR=handoff

HANDOFF_ENABLED=true
HANDOFF_TRIGGERS=angry_sentiment,explicit_request,two_failures,keywords

CHANNEL_WEB_WIDGET=true

ADMIN_ENABLED=true
ADMIN_PORT=3000
ADMIN_SECRET_KEY=

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
